# Server environment variables
# Copy this file to .env and fill in your values.

# Database
# Format:
# postgresql://user:password@ep-xxx.region.aws.neon.tech/dbname?sslmode=require
DATABASE_URL=postgresql://REPLACE_ME

# Better Auth
BETTER_AUTH_SECRET=REPLACE_ME_WITH_SECURE_SECRET
BETTER_AUTH_URL=http://localhost:3001

# Frontend origin
FRONTEND_URL=http://localhost:5173

# AI
OPENAI_API_KEY=sk-REPLACE_ME
GEMINI_API_KEY=REPLACE_ME
GEMINI_MODEL=gemini-2.5-flash

# Optional: dedicated secret for encrypting broker/API tokens at rest.
# Falls back to BETTER_AUTH_SECRET if unset.
INTEGRATION_ENCRYPTION_SECRET=REPLACE_ME_WITH_RANDOM_SECRET

# Kite Connect integration
KITE_API_KEY=REPLACE_ME
KITE_API_SECRET=REPLACE_ME
KITE_REDIRECT_URI=http://localhost:3001/api/integrations/kite/callback

# Groww integration
# Option 1: direct daily access token generated from Groww Trading APIs settings
GROWW_ACCESS_TOKEN=
# Option 2: API key + secret approval flow
GROWW_API_KEY=
GROWW_API_SECRET=

# Google Gmail investment email sync
# Create an OAuth client in Google Cloud and add this redirect URI there:
# http://localhost:3001/api/integrations/google-investments/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3001/api/integrations/google-investments/callback
# Optional: pipe-separated or newline-separated Gmail search queries.
# Defaults target Groww, CAMS, KFintech, MF Central, CDSL, NSDL, CAS, SIP, and mutual fund subjects.
GMAIL_INVESTMENT_QUERIES=
GMAIL_INVESTMENT_RECENCY=newer_than:365d
GMAIL_INVESTMENT_MAX_MESSAGES=150
INVESTMENT_EMAIL_AUTO_SYNC_ENABLED=true
INVESTMENT_EMAIL_AUTO_SYNC_INTERVAL_HOURS=6
AMFI_NAV_SYNC_ENABLED=true
AMFI_NAV_URL=https://www.amfiindia.com/spages/NAVAll.txt

# Telegram bot integration
TELEGRAM_BOT_TOKEN=REPLACE_ME
TELEGRAM_BOT_USERNAME=your_lifeos_bot
TELEGRAM_WEBHOOK_SECRET=REPLACE_ME_WITH_RANDOM_SECRET
# Optional for local quick-tunnel testing only. Keep unset/false in production.
TELEGRAM_SKIP_WEBHOOK_SECRET_CHECK=false

# Server
PORT=3001

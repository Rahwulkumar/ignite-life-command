# Server environment variables
# Copy this file to .env and fill in your values.

# Database
# Format:
# postgresql://user:password@ep-xxx.region.aws.neon.tech/dbname?sslmode=require
DATABASE_URL=postgresql://REPLACE_ME

# Better Auth
BETTER_AUTH_SECRET=REPLACE_ME_WITH_SECURE_SECRET
BETTER_AUTH_URL=http://localhost:3001

# Frontend origin
FRONTEND_URL=http://localhost:5173

# AI
OPENAI_API_KEY=sk-REPLACE_ME
GEMINI_API_KEY=REPLACE_ME
GEMINI_MODEL=gemini-2.5-flash

# Optional: dedicated secret for encrypting broker/API tokens at rest.
# Falls back to BETTER_AUTH_SECRET if unset.
INTEGRATION_ENCRYPTION_SECRET=REPLACE_ME_WITH_RANDOM_SECRET

# Kite Connect integration
KITE_API_KEY=REPLACE_ME
KITE_API_SECRET=REPLACE_ME
KITE_REDIRECT_URI=http://localhost:3001/api/integrations/kite/callback

# Groww integration
# Option 1: direct daily access token generated from Groww Trading APIs settings
GROWW_ACCESS_TOKEN=
# Option 2: API key + secret approval flow
GROWW_API_KEY=
GROWW_API_SECRET=

# Telegram bot integration
TELEGRAM_BOT_TOKEN=REPLACE_ME
TELEGRAM_BOT_USERNAME=your_lifeos_bot
TELEGRAM_WEBHOOK_SECRET=REPLACE_ME_WITH_RANDOM_SECRET
# Optional for local quick-tunnel testing only. Keep unset/false in production.
TELEGRAM_SKIP_WEBHOOK_SECRET_CHECK=false

# Server
PORT=3001

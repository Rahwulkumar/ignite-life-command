# Server Environment Variables
# Copy this file to .env and fill in your values

# ── Database ─────────────────────────────────────────────────
# Get this from your Neon project dashboard → Connection Details
# Format: postgresql://user:password@ep-xxx.region.aws.neon.tech/dbname?sslmode=require
DATABASE_URL=postgresql://REPLACE_ME

# ── Better Auth ───────────────────────────────────────────────
# Generate a secure secret: openssl rand -base64 32
BETTER_AUTH_SECRET=REPLACE_ME_WITH_SECURE_SECRET

# The URL this backend runs at (used by Better Auth for cookie domain)
BETTER_AUTH_URL=http://localhost:3001

# ── CORS ──────────────────────────────────────────────────────
# Your frontend dev URL
FRONTEND_URL=http://localhost:5173

# ── AI ────────────────────────────────────────────────────────
# OpenAI API key (same one you had in Supabase secrets)
OPENAI_API_KEY=sk-REPLACE_ME

# ── Server ────────────────────────────────────────────────────
PORT=3001
